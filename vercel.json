{
  "rewrites": [
    { "source": "/maintenance", "destination": "/maintenance.html" },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "env",
          "key": "MAINTENANCE_MODE",
          "value": "on"
        }
      ],
      "destination": "/maintenance"
    },
    { "source": "/(.*)", "destination": "/" }
  ]
}
