{
  "redirects": [
    {
      "source": "/maintenance.html",
      "destination": "/maintenance.html",
      "permanent": false
    },
    {
      "source": "/(.*)",
      "destination": "/maintenance.html",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ]
}
